rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /usernames/{usernameId} {
      allow read: if true;
      allow create:
        if !exists(/databases/$(database)/documents/usernames/$(usernameId))
        && usernameId.matches('^[a-z0-9_]{3,20}$')
        && request.resource.data.keys().hasOnly(['username', 'createdAt'])
        && request.resource.data.username is string
        && request.resource.data.username.matches('^[A-Za-z0-9_]{3,20}$');
      allow update, delete: if false;
    }

    match /results/{resultId} {
      allow read: if true;
      allow create:
        if !exists(/databases/$(database)/documents/results/$(resultId))
        && resultId.matches('^(5|6|7)_[0-9]{4}-[0-9]{2}-[0-9]{2}_[a-z0-9_]{3,20}$')
        && request.resource.data.keys().hasOnly(
             ['difficulty', 'date', 'username', 'status', 'timeMs', 'createdAt'])
        && request.resource.data.difficulty in [5, 6, 7]
        && request.resource.data.date is string
        && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.username is string
        && request.resource.data.username.matches('^[A-Za-z0-9_]{3,20}$')
        && request.resource.data.status in ['won', 'lost']
        && (
             (request.resource.data.status == 'won'
               && request.resource.data.timeMs is int
               && request.resource.data.timeMs > 0)
             ||
             (request.resource.data.status == 'lost'
               && request.resource.data.timeMs == null)
           );
      allow update, delete: if false;
    }
  }
}
